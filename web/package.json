{
  "name": "svg2gcode-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run wasm:build && vite",
    "wasm:build": "CARGO_TARGET_DIR=/tmp/svg2gcode-wasm-target wasm-pack build ../wasm --target web --out-dir ../web/src/wasm/pkg --dev && node ./scripts/patch-wasm-glue.mjs",
    "wasm:build:release": "CARGO_TARGET_DIR=/tmp/svg2gcode-wasm-target wasm-pack build ../wasm --target web --out-dir ../web/src/wasm/pkg --release && node ./scripts/patch-wasm-glue.mjs",
    "build": "npm run wasm:build:release && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^2.1.3",
    "tailwind-merge": "^3.3.1",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}

{
  "name": "svg2gcode-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run wasm:build && vite",
    "wasm:build": "CARGO_TARGET_DIR=/tmp/svg2gcode-wasm-target wasm-pack build ../wasm --target web --out-dir ../web/src/wasm/pkg --dev && node ./scripts/patch-wasm-glue.mjs",
    "wasm:build:release": "CARGO_TARGET_DIR=/tmp/svg2gcode-wasm-target wasm-pack build ../wasm --target web --out-dir ../web/src/wasm/pkg --release && node ./scripts/patch-wasm-glue.mjs",
    "build": "npm run wasm:build:release && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gravity-ui/icons": "^2.18.0",
    "@heroui/react": "^3.0.1",
    "@heroui/styles": "^3.0.1",
    "@svg2gcode/bridge": "file:../bridge",
    "@types/paper": "^0.12.3",
    "konva": "^10.2.3",
    "paper": "^0.12.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "react-resizable-panels": "^4.9.0",
    "svgpath": "^2.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
